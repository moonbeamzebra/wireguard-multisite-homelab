# ==============================================================================
# site-B-real-ce.env -- Public site configuration (git-tracked)
# Site B = "chalet" in the original lab (renamed to "cottage")
#
# Usage:
#   source site-B.env && source secrets-B.env
#   Then run the desired script, e.g.: sudo bash 04-network.sh
#
# Pair this with secrets-B.env (gitignored) for passwords and keys.
# ==============================================================================

# -- Identity ------------------------------------------------------------------
export SITE=B
export SITE_NAME=cottage
export SITE_LETTER=c                     # short prefix: c-router00, c-jump ...
export HOSTNAME=cottage
export SERVER00_HOSTNAME=${SITE_LETTER}-server00  # Debian KVM host hostname convention
export CE_HOSTNAME=${SITE_LETTER}-ce              # ISP CE router (OpenWRT) hostname convention
export PRIMARY_DOMAIN=cottage.lab
export SECONDARY_DOMAIN=home.lab

# -- Host physical interfaces (VMware Fusion NIC order) ------------------------
export IF_LAN=ens33           # vmnet7  -> br-ext
export IF_ISP=ens34           # vmnet10 -> br-isp
export IF_MGMT_ACCESS=ens35   # vmnet11 -> Mac bridge (WIFI) -> br-mgmt-access (jump mgmt)
export IF_ISP_REAL=ens39      # vmnet13 -> Mac bridge (RJ45) -> br-isp-real (WAN / ISP side) subnet to REAL isp CE

# -- VMware vmnet assignments (Mac Intel VMware Fusion) -----------------------
# These must match the vmnet numbers configured in VMware Fusion preferences.
# Update here if vmnets are reassigned (e.g. after a VMware upgrade).
export VNET_LAN=vmnet7       # vmnet7 -> br-ext / IF_LAN
export VNET_ISP=vmnet10      # vmnet10 -> br-isp / IF_ISP
export VNET_MGMT=vmnet11     # vmnet11 -> br-mgmt-access / IF_MGMT_ACCESS (bridged Wi-Fi)

# -- jmp00 VMware vmnet assignments (same on both sites) ----------------------
# jmp00 has 3 interfaces spanning both sites -- these are fixed regardless
# of which site env you source. Update if vmnets change.
export VNET_JMP_ETH0=vmnet11   # Bridged Wi-Fi -> internet
export VNET_JMP_ETH1=vmnet6    # site home LAN  (10.0.10.0/24)
export VNET_JMP_ETH2=vmnet7    # site cottage LAN (10.1.10.0/24)

# -- Host bridge IPs -----------------------------------------------------------
export IP_BR_EXT=10.1.10.2/24
export GW_BR_EXT=10.1.10.1

# -- CE router (OpenWRT -- ISP simulation) --------------------------------------
export CE_LAN_IP=192.168.1.1
export CE_WAN_IP=192.168.16.101

# -- Bastion VM ----------------------------------------------------------------
export BASTION_VM_NAME=${SITE_LETTER}-bastion
export BASTION_HOSTNAME=${SITE_LETTER}-bastion

# eth0 -- WAN (br-isp)
export NET_Bastion_eth0=lan-isp-real
export BASTION_IP_eth0=192.168.0.251
export BASTION_MASK_eth0=255.255.255.0
export BASTION_GW_eth0=192.168.0.1

export BASTION_IP_eth1=10.1.1.1
export BASTION_MASK_eth1=255.255.255.252

export WG_ADDR=10.0.0.2/30
export WG_ALLOWED_IPS=10.0.0.0/16,10.0.0.0/30

export ROUTE1_NET=10.1.0.0/16
export ROUTE1_GW=10.1.1.2
export ROUTE2_NET=10.0.0.0/16
export ROUTE2_GW=10.0.0.1

# -- Router00 VM ---------------------------------------------------------------
export ROUTER00_VM_NAME=${SITE_LETTER}-router00
export ROUTER00_HOSTNAME=${SITE_LETTER}-router00

export ROUTER00_IP_eth0=10.1.1.2
export ROUTER00_MASK_eth0=255.255.255.252
export ROUTER00_GW_eth0=10.1.1.1

export ROUTER00_IP_eth1=10.1.10.1
export ROUTER00_MASK_eth1=255.255.255.0

export ROUTER00_IP_eth2_20=10.1.20.1
export ROUTER00_IP_eth2_30=10.1.30.1

export DHCP_LAN10_START=10.1.10.100
export DHCP_LAN10_END=10.1.10.200
export DHCP_VLAN20_START=10.1.20.100
export DHCP_VLAN20_END=10.1.20.200
export DHCP_VLAN30_START=10.1.30.100
export DHCP_VLAN30_END=10.1.30.200

export DNS_REMOTE_DOMAIN=home.lab
export DNS_REMOTE_SERVER=10.0.10.1
export DNS_REMOTE_REVERSE=0.10.in-addr.arpa
export DNS_REMOTE_REVERSE_SERVER=10.0.10.1

export IPTABLES_ETH0_ACCEPT_1=10.0.0.0/16
export IPTABLES_ETH0_ACCEPT_2=10.1.0.0/16

export NET_eth0=lan-dmz
export NET_eth1_portgroup="lan-ext,portgroup=lan10"
export NET_eth2_portgroup="lan-int,portgroup=trunk"

export DNS_STATIC="\
      host-record=c-server00.cottage.lab,10.1.10.2
      host-record=c-ce-isp.cottage.lab,c-ce.cottage.lab,192.168.0.1
      host-record=c-bastion-dmz.cottage.lab,c-bastion.cottage.lab,10.1.1.1
      host-record=c-bastion-isp.cottage.lab,192.168.0.251
      host-record=c-bastion-wg.cottage.lab,10.0.0.2
      host-record=h-bastion-wg.home.lab,10.0.0.1
      host-record=c-router00-dmz.cottage.lab,10.1.1.2
      host-record=c-router00-lan10.cottage.lab,c-router00.cottage.lab,10.1.10.1
      host-record=c-router00-vlan20.cottage.lab,10.1.20.1
      host-record=c-router00-vlan30.cottage.lab,10.1.30.1
      host-record=jmp00.cottage.lab,10.1.10.254"

# -- Demo VMs ------------------------------------------------------------------
export DEMO_VM_PREFIX=${SITE_LETTER}-demo
export DEMO_IP_PREFIX=10.1

# -- Preseed (host Debian install) --------------------------------------------
export PRESEED_HOSTNAME=${SERVER00_HOSTNAME}
export PRESEED_DOMAIN=${PRIMARY_DOMAIN}
export PRESEED_IP=10.1.10.2
export PRESEED_NETMASK=255.255.255.0
export PRESEED_GW=10.1.10.254    # jmp00 bootstrap GW -- change to ${GW_BR_EXT} once router00 is deployed
