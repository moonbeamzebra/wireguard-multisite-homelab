# ==============================================================================
# site-A-real-ce.env -- Public site configuration (git-tracked)
# Site A = "maison" in the original lab (renamed to "home")
#
# Usage:
#   source site-A.env && source secrets-A.env
#   Then run the desired script, e.g.: sudo bash 04-network.sh
#
# Pair this with secrets-A.env (gitignored) for passwords and keys.
# ==============================================================================

# -- Identity ------------------------------------------------------------------
export SITE=A
export SITE_NAME=home                  # human label, used in VM names / DNS
export SITE_LETTER=h                     # short prefix: h-router00, h-jump ...
export HOSTNAME=home
export SERVER00_HOSTNAME=${SITE_LETTER}-server00  # Debian KVM host hostname convention
export CE_HOSTNAME=${SITE_LETTER}-ce              # ISP CE router (OpenWRT) hostname convention
export PRIMARY_DOMAIN=home.lab
export SECONDARY_DOMAIN=cottage.lab       # remote site domain

# -- Host physical interfaces (VMware Fusion NIC order) ------------------------
export IF_LAN=ens33           # vmnet6  -> br-ext  (LAN / default route)
export IF_ISP=ens34           # vmnet3  -> br-isp  (WAN / ISP side)
export IF_MGMT_ACCESS=ens35   # vmnet11 -> Mac bridge (WIFI) -> br-mgmt-access (jump mgmt)
export IF_ISP_REAL=ens39      # vmnet13 -> Mac bridge (RJ45) -> br-isp-real (WAN / ISP side) subnet to REAL isp CE

# -- VMware vmnet assignments (Mac Intel VMware Fusion) -----------------------
# These must match the vmnet numbers configured in VMware Fusion preferences.
# Update here if vmnets are reassigned (e.g. after a VMware upgrade).
export VNET_LAN=vmnet6       # vmnet6 -> br-ext / IF_LAN
export VNET_ISP=vmnet3      # vmnet3 -> br-isp / IF_ISP
export VNET_MGMT=vmnet11     # vmnet11 -> br-mgmt-access / IF_MGMT_ACCESS (bridged Wi-Fi)

# -- jmp00 VMware vmnet assignments (same on both sites) ----------------------
# jmp00 has 3 interfaces spanning both sites -- these are fixed regardless
# of which site env you source. Update if vmnets change.
export VNET_JMP_ETH0=vmnet11   # Bridged Wi-Fi -> internet
export VNET_JMP_ETH1=vmnet6    # site home LAN  (10.0.10.0/24)
export VNET_JMP_ETH2=vmnet7    # site cottage LAN (10.1.10.0/24)

# -- Host bridge IPs -----------------------------------------------------------
export IP_BR_EXT=10.0.10.2/24           # host IP on LAN segment
export GW_BR_EXT=10.0.10.1

# -- CE router (OpenWRT -- ISP simulation) --------------------------------------
export CE_LAN_IP=192.168.0.1
export CE_WAN_IP=192.168.16.100         # vmnet8 / NAT side

# -- Bastion VM ----------------------------------------------------------------
export BASTION_VM_NAME=${SITE_LETTER}-bastion
export BASTION_HOSTNAME=${SITE_LETTER}-bastion

# eth0 -- WAN (br-isp-real)
export NET_Bastion_eth0=lan-isp-real
export BASTION_IP_eth0=192.168.0.250
export BASTION_MASK_eth0=255.255.255.0
export BASTION_GW_eth0=192.168.0.1

# eth1 -- DMZ link /30 toward router00
export BASTION_IP_eth1=10.0.1.1
export BASTION_MASK_eth1=255.255.255.252

# WireGuard tunnel
export WG_ADDR=10.0.0.1/30             # local wg0 address
# AllowedIPs: remote site /16 + /30 wg tunnel (to ping remote wg0 IP)
export WG_ALLOWED_IPS=10.1.0.0/16,10.0.0.0/30

# Static routes injected by wg-quick PostUp/PostDown
export ROUTE1_NET=10.0.0.0/16          # all local LANs/VLANs -> via eth1
export ROUTE1_GW=10.0.1.2              # router00 DMZ IP
export ROUTE2_NET=10.1.0.0/16          # remote site -> via wg0
export ROUTE2_GW=10.0.0.2             # remote bastion wg0 IP

# -- Router00 VM ---------------------------------------------------------------
export ROUTER00_VM_NAME=${SITE_LETTER}-router00
export ROUTER00_HOSTNAME=${SITE_LETTER}-router00

# eth0 -- DMZ /30 toward bastion
export ROUTER00_IP_eth0=10.0.1.2
export ROUTER00_MASK_eth0=255.255.255.252
export ROUTER00_GW_eth0=10.0.1.1

# eth1 -- LAN10 (br-ext / untagged)
export ROUTER00_IP_eth1=10.0.10.1
export ROUTER00_MASK_eth1=255.255.255.0

# eth2 -- OVS trunk (VLANs 20 and 30)
export ROUTER00_IP_eth2_20=10.0.20.1
export ROUTER00_IP_eth2_30=10.0.30.1

# DHCP pools
export DHCP_LAN10_START=10.0.10.100
export DHCP_LAN10_END=10.0.10.200
export DHCP_VLAN20_START=10.0.20.100
export DHCP_VLAN20_END=10.0.20.200
export DHCP_VLAN30_START=10.0.30.100
export DHCP_VLAN30_END=10.0.30.200

# DNS forwarding to remote site
export DNS_REMOTE_DOMAIN=cottage.lab
export DNS_REMOTE_SERVER=10.1.10.1
export DNS_REMOTE_REVERSE=1.10.in-addr.arpa
export DNS_REMOTE_REVERSE_SERVER=10.1.10.1

# iptables: accepted sources on eth0 (DMZ)
export IPTABLES_ETH0_ACCEPT_1=10.1.0.0/16   # inter-site traffic
export IPTABLES_ETH0_ACCEPT_2=10.0.0.0/16   # bastion local (10.0.1.1)

# Libvirt network names (defined by 05-libvirt-nets.sh)
export NET_eth0=lan-dmz
export NET_eth1_portgroup="lan-ext,portgroup=lan10"
export NET_eth2_portgroup="lan-int,portgroup=trunk"

# Static DNS host records injected into dnsmasq
# 6-space indent required for YAML content-block alignment in 08-create-router00.sh
export DNS_STATIC="\
      host-record=h-server00.home.lab,10.0.10.2
      host-record=h-ce.home.lab,192.168.0.1
      host-record=h-bastion-dmz.home.lab,h-bastion.home.lab,10.0.1.1
      host-record=h-bastion-isp.home.lab,192.168.0.250
      host-record=h-bastion-wg.home.lab,10.0.0.1
      host-record=c-bastion-wg.cottage.lab,10.0.0.2
      host-record=h-router00-dmz.home.lab,10.0.1.2
      host-record=h-router00-lan10.home.lab,h-router00.home.lab,10.0.10.1
      host-record=h-router00-vlan20.home.lab,10.0.20.1
      host-record=h-router00-vlan30.home.lab,10.0.30.1
      host-record=jmp00.home.lab,10.0.10.254"

# -- Demo VMs ------------------------------------------------------------------
export DEMO_VM_PREFIX=${SITE_LETTER}-demo
export DEMO_IP_PREFIX=10.0               # IPs: 10.0.{lan}.{lan}

# -- Preseed (host Debian install) --------------------------------------------
export PRESEED_HOSTNAME=${SERVER00_HOSTNAME}
export PRESEED_DOMAIN=${PRIMARY_DOMAIN}
# Static IP used during Debian install -- no CIDR prefix, same subnet as IP_BR_EXT
# Avoids needing a running DHCP server (router00) before the host is deployed
export PRESEED_IP=10.0.10.2
export PRESEED_NETMASK=255.255.255.0
export PRESEED_GW=10.0.10.254    # jmp00 bootstrap GW -- change to ${GW_BR_EXT} once router00 is deployed
